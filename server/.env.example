# ==========================================
# SERVER
# ==========================================

NODE_ENV=development
PORT=5000

# ==========================================
# CLIENT
# ==========================================

CLIENT_URL=http://localhost:5173

# ==========================================
# DATABASE
# ==========================================

MONGODB_URI=mongodb://127.0.0.1:27017/assetpulse-ai

# MongoDB Atlas Example
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/assetpulse-ai

# ==========================================
# JWT
# ==========================================

JWT_SECRET=your_super_secret_jwt_key

JWT_EXPIRES_IN=7d

REFRESH_TOKEN_SECRET=your_super_secret_refresh_token

REFRESH_TOKEN_EXPIRES_IN=30d

# ==========================================
# EMAIL
# ==========================================

EMAIL_HOST=smtp.gmail.com

EMAIL_PORT=587

EMAIL_USER=example@gmail.com

EMAIL_PASSWORD=your_app_password

EMAIL_FROM=AssetPulse AI <example@gmail.com>

# ==========================================
# CLOUDINARY
# ==========================================

CLOUDINARY_CLOUD_NAME=

CLOUDINARY_API_KEY=

CLOUDINARY_API_SECRET=

# ==========================================
# SOCKET
# ==========================================

SOCKET_PORT=5000

# ==========================================
# AI SERVICE
# ==========================================

AI_SERVICE_URL=http://localhost:8000

# ==========================================
# QR CODE
# ==========================================

QR_BASE_URL=http://localhost:5173/assets

# ==========================================
# FILE UPLOAD
# ==========================================

MAX_FILE_SIZE=10485760

UPLOAD_PATH=uploads/

# ==========================================
# SECURITY
# ==========================================

BCRYPT_SALT_ROUNDS=10

RATE_LIMIT_WINDOW=15

RATE_LIMIT_MAX=100

# ==========================================
# LOGGING
# ==========================================

LOG_LEVEL=development